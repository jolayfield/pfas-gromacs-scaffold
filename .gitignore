# GROMACS binary outputs
*.tpr
*.trr
*.xtc
*.edr
*.cpt
*.log

# Generated coordinate and PDB files in build/
build/*.gro
build/*.pdb

# Run outputs (keep directory structure via .gitkeep)
runs/01_em/*
runs/02_nvt/*
runs/03_npt/*
runs/04_production/*
!runs/01_em/.gitkeep
!runs/02_nvt/.gitkeep
!runs/03_npt/.gitkeep
!runs/04_production/.gitkeep

# Simulation output directories (data lives here, not in version control)
# Keep the simulations/ directory itself tracked via .gitkeep if created
simulations/*/build/*.gro
simulations/*/build/*.pdb
simulations/*/runs/

# macOS
.DS_Store

# Environment overrides (copy from .env.template)
.env
